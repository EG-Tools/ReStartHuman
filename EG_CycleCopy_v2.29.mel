    // template
    EGCC__ovSetInt(EGCC__kDoR(),$val);

    // per-row
    int $pc=EGCC__ovInt(EGCC__kPairCount(),1);
    int $row=EGCC__ovInt(EGCC__kActiveRow(),1);
    if($row<1) $row=1; if($row>$pc) $row=$pc;
    EGCC__ovSetInt(EGCC__kRowDoR($row),$val);

    EG_CycleCopy_UI_Update();
}
global proc EG_CycleCopy_UI_OnRMode(int $axis,int $mode){
